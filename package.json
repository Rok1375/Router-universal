{
  "name": "router-universal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first, framework-agnostic orchestration router for AI assistants, agents, skills, MCP servers, plugins, and tools.",
  "license": "MIT",
  "engines": { "node": ">=22.0.0" },
  "scripts": {
    "dev:api": "tsx apps/api/src/server.ts",
    "dev:cli": "tsx apps/cli/src/index.ts",
    "nova": "tsx apps/cli/src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "npm run lint && npm run typecheck && npm test && npm run build",
    "start:api": "node dist/apps/api/src/server.js"
  },
  "dependencies": {
    "@fastify/rate-limit": "11.1.0",
    "fastify": "5.10.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/node": "26.1.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
